# ============================================================
# COHOPE CULTURE SCHOOL — ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env for local development.
# NEVER commit .env to Git.
# ============================================================

# ------------------------------------------------------------
# SERVER CONFIG
# ------------------------------------------------------------
PORT=3000
NODE_ENV=development
SITE_URL=http://localhost:3000

# ------------------------------------------------------------
# RESEND — Transactional Email (contact form + confirmations)
# Get your key at: https://resend.com → API Keys
# ------------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# The email address Resend sends FROM (must be a verified domain on Resend)
# Until you have a domain, use: onboarding@resend.dev (limited to your own email)
FROM_EMAIL=hello@cohope.org.uk

# The email address where contact form submissions are delivered
CONTACT_RECEIVER_EMAIL=info@cohope.org.uk

# ------------------------------------------------------------
# MAILCHIMP — Newsletter / Mailing List
# Get these at: https://mailchimp.com → Account → Extras → API Keys
# Audience ID: Audience → Settings → Audience name and campaign defaults → Audience ID
# Server prefix: last part of your API key e.g. "us21"
# ------------------------------------------------------------
MAILCHIMP_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-us21
MAILCHIMP_AUDIENCE_ID=xxxxxxxxxx
MAILCHIMP_SERVER_PREFIX=us21

# ------------------------------------------------------------
# TWILIO — SMS / Phone Notifications
# Get these at: https://console.twilio.com
# ------------------------------------------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Twilio phone number (the one you purchased, in E.164 format)
TWILIO_FROM_NUMBER=+441234567890

# The phone number to RECEIVE SMS alerts (your admin number)
TWILIO_ADMIN_NUMBER=+447700000000

# ------------------------------------------------------------
# SUPABASE — COHOPE database
# ------------------------------------------------------------
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# Use the service role key server-side so writes + admin reads work reliably.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ------------------------------------------------------------
# ADMIN (Phase 2 surface)
# Protect admin endpoints with a bearer token.
# Example header: Authorization: Bearer <ADMIN_API_KEY>
# ------------------------------------------------------------
ADMIN_API_KEY=your_admin_token_here
